{
  "expo": {
    "name": "OPIc Mock Test",
    "slug": "opic-mock-test",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.opic.mocktest",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "OPIc 모의고사 앱이 답변 녹음을 위해 마이크 접근 권한이 필요합니다."
        }
      ]
    ]
  }
}
